MYSTEEL_USERNAME=your_mysteel_username
MYSTEEL_PASSWORD=your_mysteel_password

# Default download directory for exported Excel files.
MYSTEEL_DOWNLOAD_DIR=E:\code\steel_price\data

# Optional: explicit Chrome/Chromium executable path.
# Leave empty to use built-in fallback detection.
MYSTEEL_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Set to true if you want to set the date manually in the browser.
MYSTEEL_MANUAL_DATE=false

# Set to true to allow runs on weekends or holidays.
MYSTEEL_FORCE_RUN_NON_WORKDAY=false

# Random startup delay before the script begins running.
MYSTEEL_RANDOM_START_ENABLED=false
MYSTEEL_RANDOM_START_MAX_MINUTES=15
